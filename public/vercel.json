{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/songs",
      "destination": "/tools/songs/index.html",
      "permanent": true
    },
    {
      "source": "/(.*)/index",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/fb",
      "destination": "https://facebook.com/nthdat.7",
      "permanent": false
    },
    {
      "source": "/fb",
      "destination": "https://facebook.com/nthdat.7",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/trangchu.html?mode=home"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}