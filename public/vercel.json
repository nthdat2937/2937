{
  "cleanUrls": false,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/", "destination": "/trangchu.html" },
    { "source": "/songs", "destination": "/tools/songs/index.html"}
  ],

  "redirects": [
    { "source": "/(.*)/index", "destination": "/$1", "permanent": true },
    { "source": "/fb", "destination": "https://facebook.com/yourpage", "permanent": false }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}