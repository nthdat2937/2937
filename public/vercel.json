{
  "cleanUrls": false,
  "trailingSlash": false,

  "redirects": [
    { "source": "/songs", "destination": "/tools/songs/index.html", "permanent": true},
    { "source": "/(.*)/index", "destination": "/$1", "permanent": true },
    { "source": "/fb", "destination": "https://facebook.com/yourpage", "permanent": false },
    { "source": "index1.html", "destination": "/", "permanent": true}
  ],

  "rewrites": [
    { "source": "/", "destination": "/trangchu.html" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}